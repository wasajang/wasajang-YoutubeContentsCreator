# ── AntiGravity 환경 변수 템플릿 ──
# 이 파일을 .env 로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env

# ═══════════════════════════════════════
# Supabase (DB + Auth)
# ═══════════════════════════════════════
# Supabase 프로젝트 URL (Settings > API > Project URL)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# Supabase anon key (Settings > API > anon public)
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ═══════════════════════════════════════
# Google Gemini (이미지 + 텍스트 통합)
# ═══════════════════════════════════════
# VITE_GEMINI_API_KEY=your-google-gemini-api-key
# Gemini 2.5 Flash Image: 이미지 생성
# Gemini 2.5 Flash: 텍스트 생성

# ═══════════════════════════════════════
# AI 이미지 생성
# ═══════════════════════════════════════
VITE_IMAGE_API_PROVIDER=mock
# Provider: mock | gemini | replicate
# VITE_IMAGE_API_KEY=your-replicate-api-key
# VITE_IMAGE_API_URL=https://api.replicate.com/v1

# ═══════════════════════════════════════
# AI 대본 생성
# ═══════════════════════════════════════
VITE_LLM_API_PROVIDER=mock
# Provider: mock | gemini | openai | anthropic
# VITE_OPENAI_API_KEY=sk-your-openai-api-key
# VITE_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ═══════════════════════════════════════
# AI 영상 생성 (Runway Gen-3)
# ═══════════════════════════════════════
VITE_VIDEO_API_PROVIDER=mock
# Provider: mock | runway
# VITE_RUNWAY_API_KEY=your-runway-api-key

# ═══════════════════════════════════════
# AI TTS 음성 생성 (Fish Speech)
# ═══════════════════════════════════════
VITE_TTS_API_PROVIDER=mock
# Provider: mock | fish-speech
# VITE_FISH_SPEECH_API_KEY=your-fish-speech-api-key
# VITE_FISH_SPEECH_API_URL=https://api.fish.audio
# VITE_FISH_SPEECH_MODEL_ID=your-voice-model-id

# ═══════════════════════════════════════
# 앱 설정
# ═══════════════════════════════════════
VITE_APP_NAME=AntiGravity
VITE_APP_VERSION=0.1.0

# ═══════════════════════════════════════
# 결제 시스템
# ═══════════════════════════════════════
# 토스페이먼츠 (국내 결제)
# VITE_TOSS_CLIENT_KEY=test_ck_...

# Stripe (국제 결제)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ※ Secret Key는 Supabase Edge Function Secrets에 저장
# supabase secrets set TOSS_SECRET_KEY=test_sk_...
# supabase secrets set STRIPE_SECRET_KEY=sk_test_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
