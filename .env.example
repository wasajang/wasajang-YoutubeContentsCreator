# cp .env.example .env

# ── AI Image Generation ──
VITE_IMAGE_API_PROVIDER=mock
# VITE_IMAGE_API_KEY=your-api-key-here
# VITE_IMAGE_API_URL=https://api.example.com/v1

# ── AI Script Generation ──
VITE_LLM_API_PROVIDER=mock
# VITE_LLM_API_KEY=your-api-key-here
# VITE_LLM_API_URL=https://api.example.com/v1

# ── Backend (Phase 2) ──
